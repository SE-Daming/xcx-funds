<view class="fund-detail-container"><view class="fund-header-card"><view class="fund-title-row"><text class="fund-name">{{a}}</text><text class="fund-code">{{b}}</text></view><view class="main-metrics"><view class="metric-main"><text class="{{['value', d && 'red', e && 'green']}}">{{c}}</text><text class="label">预估波动</text></view><view class="metric-sub"><text class="value">{{f}}</text><text class="label">预估单价</text></view><view class="metric-sub"><text class="value">{{g}}</text><text class="label">更新时间</text></view></view></view><view class="detail-card"><view class="card-title">基本信息</view><view class="data-grid"><view class="data-item"><text class="label">当前单价</text><text class="value">{{h}}</text></view><view class="data-item"><text class="label">数据日期</text><text class="value">{{i}}</text></view><view class="data-item"><text class="label">持有数量</text><text class="value">{{j}}</text></view><view class="data-item"><text class="label">入手单价</text><text class="value">{{k}}</text></view></view><view wx:if="{{l}}" class="holding-profit"><view class="divider"></view><view class="profit-row"><view class="profit-item"><text class="label">持有总值</text><text class="value">{{m}}</text></view><view class="profit-item"><text class="label">累计变动</text><view class="profit-values"><text class="{{['value', p && 'red', q && 'green']}}">{{n}}{{o}}</text><text class="{{['rate', s && 'red', t && 'green']}}">{{r}}% </text></view></view></view></view></view><view class="chart-card"><view class="card-title">价格趋势</view><view class="chart-container"><fund-chart wx:if="{{v}}" u-i="26101020-0" bind:__l="__l" u-p="{{v}}"></fund-chart></view></view><view class="bottom-actions"><button class="action-btn edit" bindtap="{{w}}">编辑藏品</button><button class="action-btn delete" bindtap="{{x}}">删除藏品</button></view></view>