<view class="edit-fund-container"><view class="fund-header"><view class="fund-name">{{a}}</view><view class="fund-code">{{b}}</view></view><view class="form-section"><view class="form-item"><view class="label">持有数量</view><input class="input" type="digit" placeholder="请输入持有数量" bindblur="{{c}}" value="{{d}}" bindinput="{{e}}"/></view><view class="form-item"><view class="label">入手单价</view><input class="input" type="digit" placeholder="请输入入手单价" bindblur="{{f}}" value="{{g}}" bindinput="{{h}}"/></view><view wx:if="{{i}}" class="form-item"><view class="label">持有总值</view><view class="readonly-value">{{j}}</view></view><view wx:if="{{k}}" class="form-item"><view class="label">当前变动</view><view class="{{['readonly-value', n && 'red', o && 'green']}}">{{l}}{{m}}</view></view><view wx:if="{{p}}" class="form-item"><view class="label">当前预估单价</view><view class="readonly-value">{{q}}</view></view><view wx:if="{{r}}" class="form-item"><view class="label">预估波动</view><view class="{{['readonly-value', v && 'red', w && 'green']}}">{{s}}{{t}}% </view></view></view><view class="action-buttons"><button class="btn cancel-btn" bindtap="{{x}}">取消</button><button class="btn save-btn" bindtap="{{y}}">保存</button></view></view>