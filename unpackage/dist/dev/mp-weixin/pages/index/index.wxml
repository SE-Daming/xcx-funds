<view class="fund-list-container"><view wx:if="{{a}}" class="dashboard-card"><view class="dashboard-header"><text class="title">今日变动</text><view class="right-tools"><view class="update-badge"><text class="update-time">{{b}}</text></view><view class="refresh-icon" bindtap="{{c}}"><text class="icon">🔄</text></view></view></view><view class="dashboard-content"><view class="gains-main"><text class="{{['amount', f && 'red', g && 'green']}}">{{d}}{{e}}</text></view><view class="dashboard-divider"></view><view class="gains-grid"><view class="grid-item"><text class="label">累计变动</text><text class="{{['value', j && 'red', k && 'green']}}">{{h}}{{i}}</text></view><view class="grid-item"><text class="label">累计变动率</text><text wx:if="{{l}}" class="{{['value', o && 'red', p && 'green']}}">{{m}}{{n}}%</text><text wx:else class="value">0.00%</text></view><view class="grid-item"><text class="label">持有总值</text><text class="value">{{q}}</text></view></view></view></view><view class="action-bar"><view class="action-item" bindtap="{{r}}"><view class="icon-box add-icon"><text class="icon">+</text></view><text class="label">添加</text></view><view class="action-item" bindtap="{{s}}"><view class="icon-box market-icon"><text class="icon">📥</text></view><text class="label">一键导入教程</text></view><view class="action-item" bindtap="{{w}}"><view class="{{['icon-box', 'edit-icon', t && 'active']}}"><text class="icon">⚙️</text></view><text class="label">{{v}}</text></view><view class="action-item" bindtap="{{x}}"><view class="icon-box setting-icon"><text class="icon">🔧</text></view><text class="label">设置</text></view></view><view class="fund-list"><view wx:if="{{y}}" class="list-header"><text class="title">我的藏品</text><text class="count">{{z}}件</text><view class="sort-bar"><picker mode="selector" range="{{B}}" value="{{C}}" bindchange="{{D}}"><view class="dropdown"><text>{{A}} ▾</text></view></picker><view class="order-toggle" catchtap="{{F}}"><text>{{E}}</text></view></view></view><view wx:for="{{G}}" wx:for-item="fund" wx:key="A" class="fund-card" bindtap="{{fund.B}}"><view class="card-main"><view class="fund-info"><view class="fund-name-row"><text class="fund-name">{{fund.a}}</text></view><view class="fund-code-row"><text class="fund-code">{{fund.b}}</text><text wx:if="{{fund.c}}" class="tag">价 {{fund.d}}</text></view></view><view class="fund-metrics"><view class="metric-item primary-metric"><text class="{{['metric-value', fund.f && 'red', fund.g && 'green']}}">{{fund.e}}</text><text class="metric-label">预估波动</text></view><view wx:if="{{H}}" class="metric-item secondary-metric"><text class="metric-value">{{fund.h}}</text><text class="metric-label">预估单价</text></view></view></view><view wx:if="{{I}}" class="card-extra"><view wx:if="{{fund.i}}" class="extra-item"><text class="label">今日</text><text class="{{['value', fund.k && 'red', fund.l && 'green']}}">{{fund.j}}</text></view><view wx:if="{{fund.m}}" class="extra-item"><text class="label">累计</text><text class="{{['value', fund.o && 'red', fund.p && 'green']}}">{{fund.n}}</text></view><view wx:if="{{fund.q}}" class="extra-item"><text class="label">总值</text><text class="value">{{fund.r}}</text></view><view wx:if="{{fund.s}}" class="extra-item"><text class="label">持有收益率</text><text class="{{['value', fund.v && 'red', fund.w && 'green']}}">{{fund.t}}</text></view></view><view wx:if="{{J}}" class="edit-overlay" catchtap="{{fund.z}}"><view class="edit-btn" catchtap="{{fund.x}}"><text>修改</text></view><view class="delete-btn" catchtap="{{fund.y}}"><text>删除</text></view></view></view><view wx:if="{{K}}" class="empty-state"><view class="empty-icon">📈</view><text class="empty-text">暂无关注的藏品</text><button class="add-btn" bindtap="{{L}}">添加藏品</button></view></view><view class="footer-spacer"></view></view>