<view class="fund-list-container"><view wx:if="{{a}}" class="dashboard-card"><view class="dashboard-header"><text class="title">今日收益(元)</text><view class="refresh-icon" bindtap="{{b}}"><text class="icon">🔄</text></view></view><view class="dashboard-content"><view class="gains-main"><text class="{{['amount', e && 'red', f && 'green']}}">{{c}}{{d}}</text></view><view class="dashboard-divider"></view><view class="gains-grid"><view class="grid-item"><text class="label">持有收益</text><text class="{{['value', i && 'red', j && 'green']}}">{{g}}{{h}}</text></view><view class="grid-item"><text class="label">持有收益率</text><text wx:if="{{k}}" class="{{['value', n && 'red', o && 'green']}}">{{l}}{{m}}%</text><text wx:else class="value">0.00%</text></view><view class="grid-item"><text class="label">持有金额</text><text class="value">{{p}}</text></view></view></view></view><view class="action-bar"><view class="action-item" bindtap="{{q}}"><view class="icon-box add-icon"><text class="icon">+</text></view><text class="label">添加</text></view><view class="action-item" bindtap="{{r}}"><view class="icon-box market-icon"><text class="icon">📊</text></view><text class="label">行情</text></view><view class="action-item" bindtap="{{v}}"><view class="{{['icon-box', 'edit-icon', s && 'active']}}"><text class="icon">⚙️</text></view><text class="label">{{t}}</text></view><view class="action-item" bindtap="{{w}}"><view class="icon-box setting-icon"><text class="icon">🔧</text></view><text class="label">设置</text></view></view><view class="fund-list"><view wx:if="{{x}}" class="list-header"><text class="title">我的自选</text><text class="count">{{y}}只</text></view><view wx:for="{{z}}" wx:for-item="fund" wx:key="w" class="fund-card" bindtap="{{fund.x}}"><view class="card-main"><view class="fund-info"><view class="fund-name-row"><text class="fund-name">{{fund.a}}</text></view><view class="fund-code-row"><text class="fund-code">{{fund.b}}</text><text wx:if="{{fund.c}}" class="tag">净 {{fund.d}}</text></view></view><view class="fund-metrics"><view class="metric-item primary-metric"><text class="{{['metric-value', fund.f && 'red', fund.g && 'green']}}">{{fund.e}}</text><text class="metric-label">估算涨幅</text></view><view wx:if="{{A}}" class="metric-item secondary-metric"><text class="metric-value">{{fund.h}}</text><text class="metric-label">估算净值</text></view></view></view><view wx:if="{{B}}" class="card-extra"><view wx:if="{{fund.i}}" class="extra-item"><text class="label">今日</text><text class="{{['value', fund.k && 'red', fund.l && 'green']}}">{{fund.j}}</text></view><view wx:if="{{fund.m}}" class="extra-item"><text class="label">持有</text><text class="{{['value', fund.o && 'red', fund.p && 'green']}}">{{fund.n}}</text></view><view wx:if="{{fund.q}}" class="extra-item"><text class="label">金额</text><text class="value">{{fund.r}}</text></view></view><view wx:if="{{C}}" class="edit-overlay" catchtap="{{fund.v}}"><view class="edit-btn" catchtap="{{fund.s}}"><text>修改</text></view><view class="delete-btn" catchtap="{{fund.t}}"><text>删除</text></view></view></view><view wx:if="{{D}}" class="empty-state"><view class="empty-icon">📈</view><text class="empty-text">暂无关注的基金</text><button class="add-btn" bindtap="{{E}}">添加基金</button></view></view><view class="footer-spacer"></view></view>